#!/usr/bin/env bash
# ============================================================
#  ph-test — Quick diagnostics for Pi-hole + Unbound DNS
# ============================================================

set -euo pipefail

append_path_dir() {
    local dir="${1}"
    if [[ -n "${dir}" && ":${PATH}:" != *":${dir}:"* ]]; then
        PATH="${PATH}:${dir}"
    fi
}

# Add standard admin binary locations so Debian/Raspberry Pi installs remain
# discoverable even when the invoking user's PATH omits sbin directories.
IFS=':' read -r -a supplemental_path_dirs <<< "${PH_TEST_SBIN_PATHS:-/usr/local/sbin:/usr/sbin:/sbin}"
for dir in "${supplemental_path_dirs[@]}"; do
    append_path_dir "${dir}"
done

usage() {
    local help_text

    help_text="$(cat <<'EOF'
# ph-test

Run Pi-hole + Unbound diagnostics against the given DNS server.

## Arguments

| Argument | Description |
|----------|-------------|
| `dns-server-ip` | Optional DNS server to test. Defaults to `127.0.0.1`. |

## Examples

| Command | Description |
|---------|-------------|
| `ph-test` | Run the full suite against `127.0.0.1` |
| `ph-test 192.0.2.53` | Run the full suite against a specific DNS server |
EOF
)"

    if command -v gum >/dev/null 2>&1 && [[ -t 1 ]]; then
        printf '%s\n' "${help_text}" | gum format
        return
    fi

    cat <<'EOF'
Usage:
  ph-test [dns-server-ip]
  ph-test --help

Run Pi-hole + Unbound diagnostics against the given DNS server.
Defaults to 127.0.0.1 when no server is provided.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "-help" || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
    usage
    exit 0
fi

# Self-elevate if not root (preserve PATH for ~/.local/bin commands)
if [[ "${EUID}" -ne 0 ]]; then
    exec sudo PATH="${PATH}" "${0}" "${@+"${@}"}"
fi

DNS_SERVER="${1:-127.0.0.1}"
GOOD_DOMAIN="google.com"
DNSSEC_FAIL_DOMAIN="dnssec-failed.org"
BLOCKED_DOMAIN="doubleclick.net"
UNBOUND_MAIN_CONF="${PH_TEST_UNBOUND_MAIN_CONF:-$(unbound-checkconf -o config-file 2>/dev/null || echo "/etc/unbound/unbound.conf")}"
UNBOUND_DIR=$(dirname "${UNBOUND_MAIN_CONF}")
UNBOUND_CONF="${PH_TEST_UNBOUND_CONF:-${UNBOUND_DIR}/unbound.conf.d/pi-hole.conf}"
PIHOLE_SETUPVARS=""
PIHOLE_TOML=""

HAS_GUM=false
command -v gum >/dev/null 2>&1 && [[ -t 1 ]] && HAS_GUM=true

declare -a SUMMARY_RESULTS=()
declare -a NEXT_STEPS=()
PASS_COUNT=0
WARN_COUNT=0
FAIL_COUNT=0
CURRENT_SECTION_TITLE=""
CURRENT_SECTION_BODY=""

_header() {
    if [[ "${HAS_GUM}" == true ]]; then
        gum style --bold --foreground 212 "$1"
    else
        printf '%s\n' "$1"
    fi
}

_box() {
    local content="$1"

    if [[ "${HAS_GUM}" == true ]]; then
        printf '%s' "${content}" | gum style --border rounded --border-foreground 240 --margin "0 0" --padding "0 1"
    else
        printf '%s\n' "${content}" | sed 's/^/  /'
    fi
}

_success() {
    if [[ "${HAS_GUM}" == true ]]; then
        gum style --foreground 76 --bold "$1"
    else
        printf '%s\n' "$1"
    fi
}

_warn() {
    if [[ "${HAS_GUM}" == true ]]; then
        gum style --foreground 214 --bold "$1"
    else
        printf '%s\n' "$1" >&2
    fi
}

_item() {
    if [[ "${HAS_GUM}" == true ]]; then
        gum style --foreground 244 "  $1"
    else
        printf '  %s\n' "$1"
    fi
}

add_result() {
    local kind="$1"
    local message="$2"

    SUMMARY_RESULTS+=("${kind}"$'\t'"${message}")

    case "${kind}" in
        PASS) PASS_COUNT=$((PASS_COUNT + 1)) ;;
        WARN) WARN_COUNT=$((WARN_COUNT + 1)) ;;
        FAIL) FAIL_COUNT=$((FAIL_COUNT + 1)) ;;
    esac
}

add_next_step() {
    local step="$1"
    local existing=""

    for existing in "${NEXT_STEPS[@]+"${NEXT_STEPS[@]}"}"; do
        [[ "${existing}" == "${step}" ]] && return 0
    done

    NEXT_STEPS+=("${step}")
}

flush_section() {
    [[ -n "${CURRENT_SECTION_TITLE}" ]] || return 0

    [[ -n "${CURRENT_SECTION_BODY}" ]] && _box "${CURRENT_SECTION_BODY%$'\n'}"
    CURRENT_SECTION_TITLE=""
    CURRENT_SECTION_BODY=""
}

header() {
    flush_section
    printf '\n'
    _header "$1"
    CURRENT_SECTION_TITLE="$1"
    CURRENT_SECTION_BODY=""
}

pass() {
    CURRENT_SECTION_BODY+="OK  $*"$'\n'
    add_result "PASS" "$*"
}

warn() {
    CURRENT_SECTION_BODY+="Warning: $*"$'\n'
    add_result "WARN" "$*"
}

fail() {
    CURRENT_SECTION_BODY+="FAIL  $*"$'\n'
    add_result "FAIL" "$*"
}

info() {
    CURRENT_SECTION_BODY+="$*"$'\n'
}

fix() {
    CURRENT_SECTION_BODY+="Fix: $*"$'\n'
    add_next_step "$*"
}

unbound_config_paths() {
    if [[ "${UNBOUND_CONF}" == "${UNBOUND_MAIN_CONF}" ]]; then
        printf '%s\n' "${UNBOUND_CONF}"
        return
    fi

    printf '%s\n%s\n' "${UNBOUND_CONF}" "${UNBOUND_MAIN_CONF}"
}

get_unbound_setting() {
    local key="${1}" path value
    while IFS= read -r path; do
        [[ -f "${path}" ]] || continue
        value=$(grep -E "^[[:space:]]*${key}:" "${path}" 2>/dev/null | tail -1 | awk '{print $2}' || true)
        if [[ -n "${value}" ]]; then
            printf '%s\n' "${value}"
            return 0
        fi
    done < <(unbound_config_paths)

    return 1
}

check_deps() {
    header "Dependencies"
    local missing=0
    for cmd in dig unbound-control unbound-checkconf ss; do
        _item "Checking ${cmd}"
        if ! command -v "${cmd}" &>/dev/null; then
            fail "Missing dependency: ${cmd}"
            case "${cmd}" in
                dig)
                    fix "sudo apt install dnsutils   # Debian/Ubuntu"
                    fix "sudo dnf install bind-utils  # Fedora/RHEL" ;;
                unbound-control|unbound-checkconf)
                    fix "sudo apt install unbound     # Debian/Ubuntu"
                    fix "sudo dnf install unbound     # Fedora/RHEL" ;;
                ss)
                    fix "sudo apt install iproute2    # Debian/Ubuntu"
                    fix "sudo dnf install iproute     # Fedora/RHEL" ;;
            esac
            missing=1
        fi
    done
    [[ "${missing}" -eq 0 ]]
}

# ── 2. Config check ──────────────────────────────────────────
test_config() {
    header "Config syntax check"
    local checkconf_out
    _item "Running sudo unbound-checkconf"
    checkconf_out=$(sudo unbound-checkconf 2>&1)
    if printf '%s\n' "${checkconf_out}" | grep -q "no errors"; then
        pass "unbound-checkconf: no errors"
    else
        fail "unbound-checkconf reported issues:"
        printf '%s\n' "${checkconf_out}"
        fix "Review the errors above in ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF}"
        fix "Check for typos, duplicate keys, or incorrect indentation"
        fix "Validate with: sudo unbound-checkconf ${UNBOUND_MAIN_CONF}"
    fi
}

# ── 3. Service status ────────────────────────────────────────
test_status() {
    header "Service status"
    _item "Running sudo unbound-control status"
    if sudo unbound-control status 2>&1 | grep -q "is running"; then
        pass "Unbound is running"
    else
        fail "Unbound does not appear to be running"
        fix "sudo systemctl start unbound"
        fix "sudo systemctl enable unbound   # start on boot"
        fix "Check logs: sudo journalctl -u unbound --no-pager -n 20"
    fi
}

# ── 4. Listening on expected port ───────────────────────────
test_listening() {
    header "Network / listening check"
    _item "Running sudo ss -tulnp"
    if sudo ss -tulnp 2>/dev/null | grep -q "unbound\|:53"; then
        pass "Unbound is listening on port 53"
        sudo ss -tulnp | grep "unbound\|:53" | while read -r line; do
            info "${line}"
        done
    else
        fail "Nothing detected on port 53 — Unbound may not be bound correctly"
        fix "Ensure ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF} has: interface: 0.0.0.0 (or 127.0.0.1) and port: 53"
        fix "Check if another DNS service is blocking port 53: sudo ss -tulnp | grep :53"
        fix "If systemd-resolved is conflicting: sudo systemctl disable --now systemd-resolved"
        fix "After config changes: sudo systemctl restart unbound"
    fi
}

# ── 5. Basic resolution ──────────────────────────────────────
test_basic_resolution() {
    header "Basic resolution  (${GOOD_DOMAIN} @ ${DNS_SERVER})"
    local result
    _item "Running dig @${DNS_SERVER} ${GOOD_DOMAIN} +short"
    result=$(dig @"${DNS_SERVER}" "${GOOD_DOMAIN}" +short 2>/dev/null)
    if [[ -n "${result}" ]]; then
        pass "Resolved ${GOOD_DOMAIN}:"
        printf '%s\n' "${result}" | while read -r ip; do info "${ip}"; done
    else
        fail "Could not resolve ${GOOD_DOMAIN}"
        fix "Verify Unbound is running: sudo unbound-control status"
        fix "Check upstream connectivity: dig @1.1.1.1 ${GOOD_DOMAIN} +short"
        fix "Ensure root hints are present: ls -la ${UNBOUND_DIR}/root.hints"
        fix "Update root hints: wget -O ${UNBOUND_DIR}/root.hints https://www.internic.net/domain/named.root"
        fix "Check for firewall rules blocking outbound DNS (port 53)"
    fi
}

# ── 6. Caching (latency comparison) ─────────────────────────
test_caching() {
    header "Cache speed test  (${GOOD_DOMAIN})"
    local t1 t2
    _item "Running dig timing query for ${GOOD_DOMAIN}"
    t1=$(dig @"${DNS_SERVER}" "${GOOD_DOMAIN}" 2>/dev/null | awk '/Query time/ {print $4}')
    _item "Running second dig timing query for ${GOOD_DOMAIN}"
    t2=$(dig @"${DNS_SERVER}" "${GOOD_DOMAIN}" 2>/dev/null | awk '/Query time/ {print $4}')
    if [[ -z "${t1}" || -z "${t2}" ]]; then
        fail "Could not measure query times (dig may have failed)"
        fix "Verify Unbound is running: sudo unbound-control status"
        return
    fi
    info "First query:  ${t1} ms"
    info "Second query: ${t2} ms"
    if [[ "${t1}" -eq 0 || "${t2}" -eq 0 ]]; then
        pass "Cache is working (0 ms query — served from cache)"
    elif [[ "${t2}" -lt "${t1}" ]]; then
        pass "Cache is working (second query faster)"
    else
        warn "Cache result inconclusive (timing may vary on fast networks)"
        fix "Check cache settings: grep -E 'msg-cache-size|rrset-cache-size' ${UNBOUND_CONF} ${UNBOUND_MAIN_CONF}"
        fix "Verify cache content: sudo unbound-control dump_cache | head -20"
    fi
}

# ── 7. DNSSEC validation ─────────────────────────────────────
test_dnssec() {
    header "DNSSEC validation"
    _item "Running dig @${DNS_SERVER} ${DNSSEC_FAIL_DOMAIN}"

    # Should SERVFAIL for a deliberately broken domain
    local status dnssec_validated=false
    status=$(dig @"${DNS_SERVER}" "${DNSSEC_FAIL_DOMAIN}" 2>/dev/null | awk '/status:/ {print $6}' | tr -d ',')
    if [[ "${status}" == "SERVFAIL" ]]; then
        dnssec_validated=true
        pass "DNSSEC working — ${DNSSEC_FAIL_DOMAIN} correctly returned SERVFAIL"
    else
        fail "Expected SERVFAIL for ${DNSSEC_FAIL_DOMAIN}, got: ${status:-no response}"
        fix "Ensure ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF} has: module-config: \"validator iterator\""
        fix "Set val-permissive-mode: no  (strict DNSSEC enforcement)"
        fix "Verify trust anchor exists: ls -la ${UNBOUND_DIR}/root.key"
        fix "Regenerate trust anchor: sudo unbound-anchor -a ${UNBOUND_DIR}/root.key"
        fix "After changes: sudo systemctl restart unbound"
    fi

    # Good domain should carry the AD (Authenticated Data) flag
    # Pi-hole (dnsmasq/FTL) strips the AD flag, so query Unbound directly when possible.
    local ad_target="${DNS_SERVER}" ad_port="" unbound_interface="" unbound_port=""
    local -a ad_port_args=() dig_args=()
    if has_pihole; then
        unbound_interface=$(get_unbound_setting "interface" || true)
        unbound_port=$(get_unbound_setting "port" || true)

        case "${unbound_interface}" in
            ""|"0.0.0.0"|"::"|"::0")
                ad_target="127.0.0.1"
                ;;
            *)
                ad_target="${unbound_interface}"
                ;;
        esac

        ad_port="${unbound_port:-5335}"
    fi
    if [[ -n "${ad_port}" ]]; then
        ad_port_args=(-p "${ad_port}")
    fi

    dig_args=(@"${ad_target}" "${GOOD_DOMAIN}" +dnssec)
    if [[ "${#ad_port_args[@]}" -gt 0 ]]; then
        dig_args+=("${ad_port_args[@]}")
    fi

    local ad_flag ad_status
    _item "Running dig ${GOOD_DOMAIN} +dnssec against ${ad_target}${ad_port:+:${ad_port}}"
    ad_flag=$(dig "${dig_args[@]}" 2>/dev/null | awk '/flags:/ {print}')
    ad_status=$(dig "${dig_args[@]}" 2>/dev/null | awk '/status:/ {print $6}' | tr -d ',')

    if printf '%s' "${ad_flag}" | grep -q " ad"; then
        pass "AD flag present on ${GOOD_DOMAIN} — DNSSEC authenticated"
    elif [[ "${dnssec_validated}" == "true" ]]; then
        warn "AD flag not exposed on direct query to ${ad_target}${ad_port:+:${ad_port}}"
        info "DNSSEC validation is still confirmed by ${DNSSEC_FAIL_DOMAIN} returning SERVFAIL"
    else
        fail "AD flag not set for ${GOOD_DOMAIN}"
        fix "Verify trust anchor: sudo unbound-anchor -a ${UNBOUND_DIR}/root.key"
        fix "Ensure ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF} has: val-permissive-mode: no"
        [[ -n "${ad_status}" ]] && fix "Direct Unbound query status from ${ad_target}${ad_port:+:${ad_port}}: ${ad_status}"
        fix "Restart after changes: sudo systemctl restart unbound"
    fi
}

HAS_PIHOLE=false

has_pihole() {
    [[ "${HAS_PIHOLE}" == "true" ]]
}

get_pihole_toml_setting() {
    local section="${1}" key="${2}" value=""
    [[ -n "${PIHOLE_TOML}" && -f "${PIHOLE_TOML}" ]] || return 1

    value=$(awk -v target_section="${section}" -v target_key="${key}" '
        function trim(str) {
            sub(/^[[:space:]]+/, "", str)
            sub(/[[:space:]]+$/, "", str)
            return str
        }

        {
            line = $0
            sub(/[[:space:]]*[#;].*$/, "", line)
            line = trim(line)
            if (line == "") {
                next
            }

            if (line ~ /^\[/) {
                current_section = tolower(line)
                gsub(/^\[|\]$/, "", current_section)
                in_target_section = (current_section == tolower(target_section))
                next
            }

            split(line, parts, "=")
            if (length(parts) < 2) {
                next
            }

            key_name = trim(parts[1])
            value_raw = trim(substr(line, index(line, "=") + 1))
            gsub(/^"|"$/, "", value_raw)

            if (tolower(key_name) == tolower(target_section "." target_key) || (in_target_section && tolower(key_name) == tolower(target_key))) {
                print tolower(value_raw)
                exit
            }
        }
    ' "${PIHOLE_TOML}" 2>/dev/null || true)

    case "${value}" in
        true|false)
            printf '%s\n' "${value}"
            return 0
            ;;
    esac

    return 1
}

get_pihole_dnssec_setting() {
    local value=""

    value=$(get_pihole_toml_setting "dns" "dnssec" || true)
    case "${value}" in
        true|false)
            printf '%s\n' "${value}"
            return 0
            ;;
    esac

    [[ -n "${PIHOLE_SETUPVARS}" && -f "${PIHOLE_SETUPVARS}" ]] || return 1
    value=$(awk -F= '
        function trim(str) {
            sub(/^[[:space:]]+/, "", str)
            sub(/[[:space:]]+$/, "", str)
            return str
        }

        toupper($1) == "DNSSEC" {
            print tolower(trim($2))
            exit
        }
    ' "${PIHOLE_SETUPVARS}" 2>/dev/null || true)

    case "${value}" in
        true|false)
            printf '%s\n' "${value}"
            return 0
            ;;
    esac

    return 1
}

init_pihole_vars() {
    if command -v pihole &>/dev/null || pgrep -x pihole-FTL &>/dev/null; then
        HAS_PIHOLE=true
        PIHOLE_SETUPVARS=$(find /etc -name "setupVars.conf" -path "*/pihole/*" 2>/dev/null | head -1)
        if [[ -f "/etc/pihole/pihole.toml" ]]; then
            PIHOLE_TOML="/etc/pihole/pihole.toml"
        fi
    fi
}

# ── Setup & security audit ──────────────────────────────────
check_user_group() {
    local label="${1}" user="${2}" group="${3}"
    if id "${user}" &>/dev/null; then
        pass "${label} user '${user}' exists"
    else
        fail "${label} user '${user}' does not exist"
        fix "sudo useradd -r -s /usr/sbin/nologin ${user}"
    fi
    if getent group "${group}" &>/dev/null; then
        pass "${label} group '${group}' exists"
    else
        fail "${label} group '${group}' does not exist"
        fix "sudo groupadd -r ${group}"
    fi
}

check_service_user() {
    local label="${1}" service="${2}" expected_user="${3}"
    local actual_user
    actual_user=$(ps -eo user,comm --no-headers 2>/dev/null \
        | awk -v svc="${service}" '$2 == svc {print $1; exit}')
    if [[ -z "${actual_user}" ]]; then
        info "${label} process '${service}' not found (may not be running)"
    elif [[ "${actual_user}" == "${expected_user}" ]]; then
        pass "${label} running as '${expected_user}'"
    else
        fail "${label} running as '${actual_user}' (expected '${expected_user}')"
        fix "Check systemd unit: systemctl cat ${service}"
    fi
}

check_ownership() {
    local path="${1}" expected_owner="${2}" label="${3}"
    if [[ ! -e "${path}" ]]; then
        info "${label}: ${path} not found — skipping"
        return
    fi
    local actual_owner
    actual_owner=$(stat -c '%U:%G' "${path}" 2>/dev/null)
    if [[ "${actual_owner}" == "${expected_owner}" ]]; then
        pass "${label} ownership ${actual_owner}"
    else
        fail "${label} owned by ${actual_owner} (expected ${expected_owner})"
        fix "sudo chown ${expected_owner} ${path}"
    fi
}

check_permissions() {
    local path="${1}" expected_perms="${2}" label="${3}"
    if [[ ! -e "${path}" ]]; then
        return
    fi
    local actual_perms
    actual_perms=$(stat -c '%a' "${path}" 2>/dev/null)
    if [[ "${actual_perms}" == "${expected_perms}" ]]; then
        pass "${label} permissions ${actual_perms}"
    else
        fail "${label} permissions ${actual_perms} (expected ${expected_perms})"
        fix "sudo chmod ${expected_perms} ${path}"
    fi
}

check_systemd_enabled() {
    local label="${1}" unit="${2}"
    if systemctl is-enabled "${unit}" &>/dev/null; then
        pass "${label} enabled on boot"
    else
        fail "${label} not enabled on boot"
        fix "sudo systemctl enable ${unit}"
    fi
}

test_setup_security() {
    header "Setup & security audit"
    _item "Inspecting service users, ownership, and permissions"

    # ── Unbound ──
    info "— Unbound —"
    check_user_group "Unbound" "unbound" "unbound"
    check_service_user "Unbound" "unbound" "unbound"
    check_systemd_enabled "Unbound" "unbound"
    check_ownership "${UNBOUND_CONF}" "root:root" "${UNBOUND_CONF}"
    check_ownership "${UNBOUND_MAIN_CONF}" "root:root" "${UNBOUND_MAIN_CONF}"
    check_ownership "${UNBOUND_DIR}" "root:root" "${UNBOUND_DIR}"

    # Unbound should listen only on loopback
    local ub_iface
    ub_iface=$(get_unbound_setting "interface" || true)
    if [[ "${ub_iface}" == "127.0.0.1" || "${ub_iface}" == "::1" ]]; then
        pass "Unbound listens on loopback only (${ub_iface})"
    elif [[ -n "${ub_iface}" ]]; then
        fail "Unbound interface is ${ub_iface} (expected 127.0.0.1)"
        fix "Set interface: 127.0.0.1 in ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF}"
    else
        info "Could not determine Unbound interface from ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF}"
    fi

    # Unbound hardening flags
    local key val actual
    for setting in "harden-glue: yes" "harden-dnssec-stripped: yes" "hide-identity: yes" "hide-version: yes"; do
        key="${setting%%:*}" val="${setting#*: }"
        actual=$(get_unbound_setting "${key}" || true)
        if [[ "${actual}" == "${val}" ]]; then
            pass "Unbound ${key}: ${actual}"
        elif [[ -z "${actual}" ]]; then
            warn "Unbound ${key} not set in ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF}"
            fix "Add to server: section in ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF}: ${setting}"
        else
            fail "Unbound ${key}: ${actual} (expected ${val})"
            fix "Set ${setting} in ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF}"
        fi
    done

    # Check unbound-resolvconf is disabled (conflicts with Pi-hole)
    if has_pihole && systemctl is-active unbound-resolvconf &>/dev/null; then
        fail "unbound-resolvconf is active (conflicts with Pi-hole)"
        fix "sudo systemctl disable --now unbound-resolvconf.service"
    fi

    # ── Pi-hole ──
    if has_pihole; then
        info "— Pi-hole —"
        check_user_group "Pi-hole" "pihole" "pihole"
        check_service_user "Pi-hole" "pihole-FTL" "pihole"
        check_systemd_enabled "Pi-hole" "pihole-FTL"

        if [[ -n "${PIHOLE_SETUPVARS}" ]]; then
            local pihole_dir
            pihole_dir=$(dirname "${PIHOLE_SETUPVARS}")
            check_ownership "${pihole_dir}" "pihole:pihole" "${pihole_dir}"
            check_permissions "${pihole_dir}" "755" "${pihole_dir}"
        else
            warn "Could not locate Pi-hole config directory — skipping ownership checks"
            fix "find /etc -name 'setupVars.conf' -path '*/pihole/*'"
        fi

        if [[ -d "/var/log/pihole" ]]; then
            check_ownership "/var/log/pihole" "pihole:pihole" "/var/log/pihole"
        fi

        if [[ -n "${PIHOLE_SETUPVARS}" || -n "${PIHOLE_TOML}" ]]; then
            # Pi-hole should NOT have its own DNSSEC enabled when Unbound handles it
            local pihole_dnssec
            pihole_dnssec=$(get_pihole_dnssec_setting || true)
            if [[ "${pihole_dnssec}" == "true" ]]; then
                fail "Pi-hole DNSSEC is enabled (Unbound already handles DNSSEC)"
                fix "Disable DNSSEC in Pi-hole web UI: Settings > DNS > uncheck DNSSEC"
            elif [[ "${pihole_dnssec}" == "false" ]]; then
                pass "Pi-hole DNSSEC correctly deferred to Unbound"
            else
                warn "Could not determine Pi-hole DNSSEC setting from live config"
                fix "Check Pi-hole DNS setting in /etc/pihole/pihole.toml or the web UI"
            fi

            # Pi-hole upstream should point to Unbound
            if [[ -n "${PIHOLE_SETUPVARS}" ]]; then
                local upstream
                upstream=$(grep -i 'PIHOLE_DNS' "${PIHOLE_SETUPVARS}" 2>/dev/null | head -1 | cut -d= -f2 || true)
                if [[ "${upstream}" == *"127.0.0.1#5335"* ]]; then
                    pass "Pi-hole upstream points to Unbound (${upstream})"
                elif [[ -n "${upstream}" ]]; then
                    warn "Pi-hole upstream: ${upstream} (expected 127.0.0.1#5335)"
                    fix "Set Custom DNS in Pi-hole to 127.0.0.1#5335"
                fi
            fi
        fi
    fi
}

test_blocklist() {
    header "Blocklist / RPZ check  (${BLOCKED_DOMAIN})"
    local dig_out result rcode
    _item "Running dig @${DNS_SERVER} ${BLOCKED_DOMAIN}"
    dig_out=$(dig @"${DNS_SERVER}" "${BLOCKED_DOMAIN}" 2>/dev/null)
    result=$(printf '%s\n' "${dig_out}" | awk '/^[^;]/ && NF >= 5 {print $5}')
    rcode=$(printf '%s\n' "${dig_out}" | awk '/status:/ {print $6}' | tr -d ',')
    if [[ "${rcode}" == "NXDOMAIN" || "${result}" == "0.0.0.0" || "${result}" == "::" || -z "${result}" ]]; then
        pass "${BLOCKED_DOMAIN} appears to be blocked (${rcode:-no answer})"
    else
        warn "${BLOCKED_DOMAIN} resolved to: ${result} (expected blocked)"
        if has_pihole; then
            fix "Check Pi-hole gravity: pihole -q ${BLOCKED_DOMAIN}"
            fix "Update gravity database: pihole -g"
            fix "Add to blacklist: pihole -b ${BLOCKED_DOMAIN}"
            [[ -n "${PIHOLE_SETUPVARS}" ]] && fix "Verify Pi-hole upstream is Unbound: grep -i 'pihole_dns' ${PIHOLE_SETUPVARS}"
        else
            fix "Verify RPZ zone is loaded: sudo unbound-control list_local_zones | grep rpz"
            fix "Check blocklist config: grep -E 'rpz|local-zone' ${UNBOUND_CONF} ${UNBOUND_MAIN_CONF}"
            fix "Reload blocklist: sudo unbound-control reload"
        fi
    fi
}

# ── 9. Stats snapshot ───────────────────────────────────────
test_stats() {
    header "Unbound stats snapshot"
    local stats
    _item "Running sudo unbound-control stats_noreset"
    stats=$(sudo unbound-control stats_noreset 2>/dev/null || true)
    if [[ -n "${stats}" ]]; then
        local key val
        for key in total.num.queries total.num.cachehits total.num.cachemiss \
                   total.num.recursivereplies num.query.type.A num.query.type.AAAA; do
            val=$(printf '%s\n' "${stats}" | grep "^${key}=" | cut -d= -f2 || true)
            [[ -n "${val}" ]] && info "${key}: ${val}"
        done
    else
        fail "Could not retrieve stats (is unbound-control configured?)"
        fix "Enable remote control in ${UNBOUND_CONF} or ${UNBOUND_MAIN_CONF}:"
        fix "  remote-control:"
        fix "    control-enable: yes"
        fix "    control-interface: 127.0.0.1"
        fix "Generate control keys: sudo unbound-control-setup"
        fix "After changes: sudo systemctl restart unbound"
    fi
}

print_intro() {
    local section=""

    _header "ph-test"
    section+="DNS server: ${DNS_SERVER}"$'\n'
    section+="Unbound include: ${UNBOUND_CONF}"$'\n'
    section+="Unbound main: ${UNBOUND_MAIN_CONF}"$'\n'
    section+="Pi-hole detected: ${HAS_PIHOLE}"
    _box "${section}"
}

main() {
    check_deps || {
        flush_section
        print_summary
        return 1
    }

    init_pihole_vars
    print_intro
    test_setup_security
    test_config
    test_status
    test_listening
    test_basic_resolution
    test_caching
    test_dnssec
    test_blocklist
    test_stats

    flush_section
    print_summary
}

print_summary() {
    local entry=""
    local kind=""
    local message=""
    local summary_body=""
    local step=""
    local steps_body=""

    printf '\n'
    _header "Summary"

    summary_body="passed: ${PASS_COUNT}"$'\n'"warnings: ${WARN_COUNT}"$'\n'"failed: ${FAIL_COUNT}"
    for entry in "${SUMMARY_RESULTS[@]}"; do
        kind="${entry%%$'\t'*}"
        message="${entry#*$'\t'}"
        summary_body+=$'\n'
        summary_body+="${kind}  ${message}"
    done

    _box "${summary_body}"
    printf '\n'

    if [[ "${FAIL_COUNT}" -eq 0 && "${WARN_COUNT}" -eq 0 ]]; then
        if [[ "${HAS_GUM}" == true ]]; then
            gum style --foreground 76 --bold "Passed: ${PASS_COUNT}  Warnings: ${WARN_COUNT}  Failed: ${FAIL_COUNT}"
            gum style --foreground 76 --bold "All checks passed."
        else
            printf 'Passed: %s  Warnings: %s  Failed: %s\n' "${PASS_COUNT}" "${WARN_COUNT}" "${FAIL_COUNT}"
            printf 'All checks passed.\n'
        fi
        return 0
    fi

    if [[ "${HAS_GUM}" == true ]]; then
        gum style --foreground 76 --bold "Passed: ${PASS_COUNT}"
        gum style --foreground 214 --bold "Warnings: ${WARN_COUNT}"
        gum style --foreground 196 --bold "Failed: ${FAIL_COUNT}"
    else
        printf 'Passed: %s  Warnings: %s  Failed: %s\n' "${PASS_COUNT}" "${WARN_COUNT}" "${FAIL_COUNT}"
    fi

    if [[ "${FAIL_COUNT}" -eq 0 ]]; then
        _warn "Completed with ${WARN_COUNT} warning(s)."
    else
        _warn "Found ${FAIL_COUNT} failing check(s)."
    fi

    add_next_step "Check config with: sudo unbound-checkconf"
    add_next_step "View logs with: sudo journalctl -u unbound --no-pager -n 30"
    add_next_step "Restart Unbound with: sudo systemctl restart unbound"
    add_next_step "Re-run tests with: ${0} ${DNS_SERVER}"

    for step in "${NEXT_STEPS[@]+"${NEXT_STEPS[@]}"}"; do
        steps_body+="- ${step}"$'\n'
    done

    if [[ -n "${steps_body}" ]]; then
        printf '\n'
        _header "Next Steps"
        _box "${steps_body%$'\n'}"
    fi

    [[ "${FAIL_COUNT}" -eq 0 ]]
}

main "$@"
