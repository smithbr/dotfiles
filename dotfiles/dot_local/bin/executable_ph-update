#!/usr/bin/env bash

set -euo pipefail

# Self-elevate if not root
if [[ "${EUID}" -ne 0 ]]; then
    exec sudo "${0}" "${@}"
fi

# Update packages
apt-get update --fix-missing
apt-get full-upgrade -y
apt-get autoremove --purge -y
apt-get autoclean -y
apt-get clean

# Update Pi-hole
pihole -up

# Update PADD
ph-padd -u

# Reboot the system
# reboot
