export GNUPGHOME="${XDG_DATA_HOME}/gnupg"
export DOCKER_CONFIG="${XDG_CONFIG_HOME}/docker"
export MACHINE_STORAGE_PATH="${XDG_DATA_HOME}/docker-machine"
export HISTFILE="${XDG_STATE_HOME}/zsh/history"
export NPM_CONFIG_CACHE="${XDG_CACHE_HOME}/npm"
export NPM_CONFIG_INIT_MODULE="${XDG_CONFIG_HOME}/npm/config/npm-init.js"
export NPM_CONFIG_TMP="${XDG_RUNTIME_DIR}/npm"
export PATH="${HOME}/.local/bin:${PATH}"
export ZDOTDIR="${XDG_CONFIG_HOME}/zsh"
export RUSTUP_HOME="${XDG_DATA_HOME}/rustup"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${HOME}/.cache}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-${HOME}/.local/run}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-${HOME}/.local/state}"

if [[ -S "${HOME}/.1password/agent.sock" ]]; then
    export SSHKEY_IDENTITY_AGENT="${HOME}/.1password/agent.sock"
    export SSH_AUTH_SOCK="${SSHKEY_IDENTITY_AGENT}"
fi

export NVM_DIR="${XDG_CONFIG_HOME}/nvm"
[ -s "/usr/local/opt/nvm/nvm.sh" ] && \. "/usr/local/opt/nvm/nvm.sh"  # This loads nvm
[ -s "/usr/local/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/usr/local/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion

source "${XDG_CONFIG_HOME}/shell/aliases"
source "${XDG_CONFIG_HOME}/shell/functions"

# Bootstrap Homebrew into PATH if not already available
if ! command -v brew >/dev/null 2>&1; then
    if [[ -x /opt/homebrew/bin/brew ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -x /usr/local/bin/brew ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    fi
fi

# Local overrides
if [[ -f "${XDG_CONFIG_HOME}/zsh/zshrc.local" ]]; then
    source "${XDG_CONFIG_HOME}/zsh/zshrc.local"
elif [[ -f "${HOME}/.zshrc.local" ]]; then
    source "${HOME}/.zshrc.local"
fi

if command -v brew >/dev/null 2>&1; then
    antidote_zsh="$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh"
    if [[ -f "${antidote_zsh}" ]]; then
        source "${antidote_zsh}"
        antidote load "${XDG_CONFIG_HOME}/zsh/plugins.txt"
    else
        printf '%s\n' "antidote not found at ${antidote_zsh}" >&2
    fi
elif command -v antidote >/dev/null 2>&1; then
    antidote load "${XDG_CONFIG_HOME}/zsh/plugins.txt"
else
    printf '%s\n' "brew is not available; cannot load antidote" >&2
fi

if command -v starship >/dev/null 2>&1; then
    eval "$(starship init zsh)"
fi

fpath+=~/.zfunc; autoload -Uz compinit; compinit -d "${XDG_CACHE_HOME}/zsh/zcompdump-${ZSH_VERSION}"

zstyle ':completion:*' menu select
