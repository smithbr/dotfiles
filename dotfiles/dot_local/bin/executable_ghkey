#!/usr/bin/env bash

set -euo pipefail

FORCE=false
if [[ "${1:-}" == "--force" || "${1:-}" == "-f" ]]; then
    FORCE=true
fi

EMAIL="1495361+smithbr@users.noreply.github.com"
KEY="${HOME}/.ssh/id_ed25519"

if [[ "${FORCE}" == false ]]; then
    printf '🔍 Checking for existing GitHub SSH connection...\n'
    if ssh -T git@github.com 2>&1 | grep -q "successfully authenticated"; then
        printf '✅ Already authenticated with GitHub — no setup needed\n'
        exit 0
    fi
else
    if [[ -f "${KEY}" ]]; then
        printf '🗑  Removing existing key pair...\n'
        rm -f "${KEY}" "${KEY}.pub"
        ssh-add -d "${KEY}" 2>/dev/null
    fi
fi

printf '🔑 Generating SSH key for %s...\n' "${EMAIL}"
ssh-keygen -t ed25519 -C "${EMAIL}" -f "${KEY}"

printf '📋 Adding key to ssh-agent...\n'
ssh-add "${KEY}"

printf '\n'
printf '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n'
printf 'Your public key:\n'
printf '\n'
cat "${KEY}.pub"
printf '━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n'
printf '\n'
printf '👆 Copy the key above and add it at:\n'
printf '   https://github.com/settings/keys\n'
printf '\n'
read -rp "Press enter when done (Ctrl+C to cancel)..."

printf '\n'
printf '🔗 Testing connection to GitHub...\n'
if ssh -T git@github.com 2>&1 | grep -q "successfully authenticated"; then
    printf '✅ Success!\n'
else
    printf '❌ Something went wrong. Check your key was added correctly.\n'
fi
