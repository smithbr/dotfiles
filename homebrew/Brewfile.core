# Install all dependencies with: brew bundle
# Usage: brew bundle [--file=Brewfile.core]

# Core Tools
brew "git"
brew "gh"
brew "lazygit"
brew "gnupg"
brew "ripgrep"
brew "glances"
brew "htop"
brew "nethogs"
brew "node"
brew "nvm"
brew "pnpm"
brew "wget"
brew "curl"
brew "domain-check"
brew "zsh"
brew "docker"
tap "sinelaw/fresh"
brew "fresh-editor"

# Shell Enhancements
brew "antidote"
brew "asciiquarium"
brew "bat"
brew "nerdfetch"
brew "onefetch"
brew "starship"
brew "tree"
