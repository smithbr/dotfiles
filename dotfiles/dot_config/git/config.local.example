# Machine-specific git config overrides
# Copy to ~/.config/git/config.local

# [user]
#     name = Your Name
#     email = you@example.com
#     username = your-github-username

############
# --- macOS (1Password SSH agent) ---
############
# No sshCommand needed — 1Password agent handles key selection via SSH_AUTH_SOCK.
# [credential]
#     helper = osxkeychain
# [core]
#     editor = code
# [diff]
#     tool = code
# [merge]
#     tool = code
# [user]
#     signingkey = ~/.ssh/id_ed25519.pub
# [commit]
#     gpgsign = true
# [gpg]
#     format = ssh
# [gpg "ssh"]
#     program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

############
# --- Linux (keys on disk) ---
############
# [credential]
#     helper = store
# [core]
#     editor = nano
#     pager = delta
#     sshCommand = ssh -i ~/.ssh/id_ed25519 -o AddKeysToAgent=yes
# [interactive]
#     diffFilter = delta --color-only
# [delta]
#     navigate = true
#     true-color = always
#     line-numbers = true
#     side-by-side = true
# [merge]
#     conflictStyle = zdiff3
#     tool = vimdiff
# [diff]
#     colorMoved = default
#     tool = vimdiff
