#!/usr/bin/env bash

set -euo pipefail

# Preserve user's PATH through sudo for ~/.local/bin commands
if [[ "${EUID}" -ne 0 ]]; then
    exec sudo PATH="${PATH}" "${0}" "${@}"
fi

# Update packages
apt-get update --fix-missing
apt-get full-upgrade -y
apt-get autoremove --purge -y
apt-get autoclean -y
apt-get clean

# Update Pi-hole
pihole -up

# Update PADD
ph-padd -u

# Reboot the system
# reboot
