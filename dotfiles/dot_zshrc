export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export PATH="$HOME/.local/bin:$PATH"
export OPENCODE_CONFIG_DIR="${XDG_CONFIG_HOME}/agents/tools/opencode"

source "${XDG_CONFIG_HOME}/shell/aliases"

# Bootstrap Homebrew into PATH if not already available
if ! command -v brew >/dev/null 2>&1; then
    if [[ -x /opt/homebrew/bin/brew ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -x /usr/local/bin/brew ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    fi
fi

# Local overrides
if [[ -f "${HOME}/.zshrc.local" ]]; then
    source "${HOME}/.zshrc.local"
fi

if command -v brew >/dev/null 2>&1; then
    antidote_zsh="$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh"
    if [[ -f "${antidote_zsh}" ]]; then
        source "$antidote_zsh"
        antidote load "${XDG_CONFIG_HOME}/zsh/plugins.txt"
    else
        echo "antidote not found at $antidote_zsh" >&2
    fi
elif command -v antidote >/dev/null 2>&1; then
    antidote load "${XDG_CONFIG_HOME}/zsh/plugins.txt"
else
    echo "brew is not available; cannot load antidote" >&2
fi

if command -v starship >/dev/null 2>&1; then
    eval "$(starship init zsh)"
fi

# Smart Tab: accept suggestion if present, otherwise do normal completion
function __smart_completion() {
  if [ -n "$POSTDISPLAY" ]; then
    zle autosuggest-accept
  else
    zle expand-or-complete
  fi
}

zle -N __smart_completion
bindkey '\t' __smart_completion

fpath+=~/.zfunc; autoload -Uz compinit; compinit

zstyle ':completion:*' menu select
