# Shared git defaults (machine-specific overrides live in ~/.config/git/config.local)

[core]
    ignorecase = false

[include]
    path = ~/.config/git/config.local

[init]
    defaultBranch = main

[difftool]
    prompt = false

[pull]
    rebase = true

[push]
    autoSetupRemote = true
    default = current

[rebase]
    updateRefs = true

[alias]
    st = status -sb
    co = checkout
    cob = checkout -b
    nuke = reset --hard
    br = branch
    l = log --graph --pretty=format:'%Cred%h%Creset %C(yellow)%an%d%Creset %s %Cgreen(%cr)%Creset' --date=relative
    lg   = log --oneline --graph --decorate --all
    last = log -1 HEAD --stat
    ls   = log --stat
    undo = !git reset --soft HEAD^1 && git reset
    cleanup = !git branch --no-color | fzf -m | xargs -I {} git branch -D '{}'
    clean-all = !git reset --hard && git clean -xfd
    recent = branch --sort=-committerdate
